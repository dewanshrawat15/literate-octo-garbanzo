# ─── Backend ──────────────────────────────────────────────────────────────────

# Deepgram speech-to-text API key (required)
# Get one at https://console.deepgram.com
DEEPGRAM_API_KEY=

# Cartesia text-to-speech API key (required)
# Get one at https://play.cartesia.ai
CARTESIA_API_KEY=

# Cartesia voice ID (optional, uses a default English voice if omitted)
CARTESIA_VOICE_ID=71a7ad14-091c-4e8e-a314-022ece01c121

# JWT signing secret — change this to a long random string in production
JWT_SECRET=change-me-in-production

# Server bind address and port
HOST=0.0.0.0
PORT=8000

# Path to the SQLite database file
# When using Docker Compose this is set to /app/data/spelling_bee.db automatically
DB_PATH=spelling_bee.db

# ─── Frontend ─────────────────────────────────────────────────────────────────

# Base URL of the backend API (no trailing slash)
# In Docker Compose this is set automatically
VITE_BACKEND_URL=http://localhost:8000
